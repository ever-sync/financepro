{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "public",
  "functions": {
    "api/trpc/[trpc].ts": {
      "maxDuration": 30,
      "includeFiles": "dist/trpc-vercel.js"
    },
    "api/asaas/webhook.ts": {
      "maxDuration": 30,
      "includeFiles": "dist/asaas-webhook.js"
    },
    "api/whatsapp/uazapi/webhook.ts": {
      "maxDuration": 30,
      "includeFiles": "dist/whatsapp-webhook.js"
    },
    "api/cron/financial-daily.ts": {
      "maxDuration": 30,
      "includeFiles": "dist/assistant-cron.js"
    },
    "api/cron/financial-month-start.ts": {
      "maxDuration": 30,
      "includeFiles": "dist/assistant-cron.js"
    },
    "api/cron/financial-month-end.ts": {
      "maxDuration": 30,
      "includeFiles": "dist/assistant-cron.js"
    }
  },
  "rewrites": [
    { "source": "/api/trpc/:path*", "destination": "/api/trpc/[trpc]" },
    { "source": "/((?!api/|assets/|favicon\\.svg$).*)", "destination": "/index.html" }
  ]
}
